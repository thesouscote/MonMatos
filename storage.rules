rules_version = '2';
service firebase.storage {
  match /b/{bubble}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null; // On autorise la lecture si connecté (pour les checklists partagées plus tard?)
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
