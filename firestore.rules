rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chaque utilisateur ne peut accéder qu'à son propre document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Règles pour les transferts de matériel entre comptes
    match /transfers/{transferId} {
      // Pour créer, il faut être connecté et envoyer en tant que soi-même
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      // Pour lire/mettre à jour/supprimer, il faut être l'expéditeur ou le destinataire
      allow read, update, delete: if request.auth != null && (
        resource.data.fromUid == request.auth.uid || 
        resource.data.toEmail == request.auth.token.email
      );
    }
  }
}
